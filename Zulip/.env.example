# Required by Zulip's Docker image.
ZULIP_EXTERNAL_HOST=localhost.localdomain:8443
ZULIP_ADMINISTRATOR=admin@example.com

# Optional image pin.
ZULIP_IMAGE_TAG=11.6-1
ZULIP_CERTIFICATES=self-signed

# High host ports so Zulip can run alongside the other chat stacks.
ZULIP_HTTP_PORT=8088
ZULIP_HTTPS_PORT=8443
ZULIP_SMTP_PORT=2525